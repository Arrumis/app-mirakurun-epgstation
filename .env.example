# Mirakurun / EPGStation の基本設定です。

# 永続化データの保存先です。
# HOST_DATA_DIR を基準に、下の各ディレクトリへ役割別に保存します。
HOST_DATA_DIR=./data
RECORDED_DIR=./recorded
MIRAKURUN_CONFIG_DIR=./data/mirakurun/conf
MIRAKURUN_DATA_DIR=./data/mirakurun/data
EPG_DB_DIR=./data/mariadb
EPGSTATION_CONFIG_DIR=./data/epgstation/config
EPGSTATION_DATA_DIR=./data/epgstation/data
EPGSTATION_THUMBNAIL_DIR=./data/epgstation/thumbnail
EPGSTATION_LOGS_DIR=./data/epgstation/logs

# コンテナ内タイムゾーンです。
TZ=Asia/Tokyo

# 旧環境の Mirakurun 設定を流用したい場合だけ指定します。
LEGACY_MIRAKURUN_CONF_DIR=

# 公開ポートです。
MIRAKURUN_PORT=40772
MIRAKURUN_DEBUG_PORT=9229
EPGSTATION_PORT=8888
EPGSTATION_PREVIEW_PORT=8889

# アプリ間通信の設定です。
MIRAKURUN_HOSTNAME=localhost
EPG_MIRAKURUN_URL=http://mirakurun:40772/

# DB 接続情報です。
EPG_DB_NAME=epgstation
EPG_DB_HOST=epg-sql
EPG_DB_PORT=3306
EPG_DB_USER=epgstation
EPG_DB_PASSWORD=change-me
EPG_DB_ROOT_PASSWORD=change-me-root

# コンテナ内で使う UID / GID です。
EPGSTATION_UID=1000
EPGSTATION_GID=1000
